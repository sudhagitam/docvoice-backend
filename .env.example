# DocVoice AI – Cloud Run Environment Variables
# Set these via: gcloud run services update docvoice-backend --set-env-vars KEY=VALUE

# CORS – your Vercel frontend URL
ALLOWED_ORIGINS=https://your-app.vercel.app

# Limits
MAX_UPLOAD_BYTES=104857600   # 100 MB
MAX_TEXT_CHARS=200000

# TTS defaults
DEFAULT_LANG=en

# Temp directory (always /tmp on Cloud Run)
TMP_DIR=/tmp/docvoice
